@page "/"
@inject IProductService ProductService
@inject ICartService CartService
@inject IJSRuntime JS

<PageTitle>Yare — Luxury Watches &amp; Jewellery</PageTitle>

<!-- Hero Slider -->
<section id="slider-hmPg-Container">
    <div class="slider-hmPg">

        <div class="slide-hmPg">
            <div class="slide-1-Img"></div>
            <div class="slide-1-infoContent">
                <p class="text-white" style="font-size:clamp(11px,1.4vw,14px)">
                    Discover Audemars Piguet's iconic design and craftsmanship, a true embodiment of uncompromising luxury.
                </p>
                <a href="collections" class="nav-link text-white slide-1-Btn navLink-Animation">Explore The Collection</a>
            </div>
        </div>

        <div class="slide-hmPg">
            <div class="slide-2-Img"></div>
            <div class="slide-2-infoContent">
                <p class="text-white" style="font-size:clamp(11px,1.4vw,14px)">
                    Experience timeless elegance with our diamond jewellery collection.
                </p>
                <a href="jewellery" class="nav-link text-white slide-2-Btn navLink-Animation">Explore The Collection</a>
            </div>
        </div>

        <div class="slide-hmPg">
            <div class="slide-3-Img"></div>
            <div class="slide-3-infoContent">
                <p class="text-white" style="font-size:clamp(11px,1.4vw,14px)">
                    Discover our engagement ring collection — masterful design meets deep emotion.
                </p>
                <a href="jewellery" class="nav-link text-white slide-3-Btn navLink-Animation">Explore The Collection</a>
            </div>
        </div>

        <div class="sliderControls-Container-hmPg">
            <button class="slider__btn-hmPg slider__btn--left-hmPg" id="sliderBtnLeft">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M11.7803 5.22431C12.0732 5.5172 12.0732 5.99208 11.7803 6.28497L8.06066 10.0046L11.7803 13.7243C12.0732 14.0172 12.0732 14.4921 11.7803 14.785C11.4874 15.0779 11.0126 15.0779 10.7197 14.785L6.46967 10.535C6.17678 10.2421 6.17678 9.7672 6.46967 9.47431L10.7197 5.22431C11.0126 4.93142 11.4874 4.93142 11.7803 5.22431Z" fill="red" />
                </svg>
            </button>
            <div class="dots-hmPg" id="sliderDots"></div>
            <button class="slider__btn-hmPg slider__btn--right-hmPg" id="sliderBtnRight">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M8.21967 5.22431C8.51256 4.93142 8.98744 4.93142 9.28033 5.22431L13.5303 9.47431C13.8232 9.7672 13.8232 10.2421 13.5303 10.535L9.28033 14.785C8.98744 15.0779 8.51256 15.0779 8.21967 14.785C7.92678 14.4921 7.92678 14.0172 8.21967 13.7243L11.9393 10.0046L8.21967 6.28497C7.92678 5.99208 7.92678 5.5172 8.21967 5.22431Z" fill="red" />
                </svg>
            </button>
        </div>
    </div>
</section>

<div class="hmPg-Wrapper">

    <!-- Service Banner -->
    <section id="service-banner-Container">
        <div class="serviceFeature-itemContainer">
            <svg class="serviceFeatureSvg-Icons" viewBox="0 0 22 17" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M2.375 0.504639C1.33947 0.504639 0.5 1.3441 0.5 2.37964V9.50464H12.5V2.37964C12.5 1.3441 11.6605 0.504639 10.625 0.504639H2.375Z" fill="black" />
                <path d="M12.5 11.0046H0.5V13.6296C0.5 14.6652 1.33947 15.5046 2.375 15.5046H2.75C2.75 13.8478 4.09315 12.5046 5.75 12.5046C7.40685 12.5046 8.75 13.8478 8.75 15.5046H11.75C12.1642 15.5046 12.5 15.1689 12.5 14.7546V11.0046Z" fill="black" />
                <path d="M7.25 15.5046C7.25 14.6762 6.57843 14.0046 5.75 14.0046C4.92157 14.0046 4.25 14.6762 4.25 15.5046C4.25 16.3331 4.92157 17.0046 5.75 17.0046C6.57843 17.0046 7.25 16.3331 7.25 15.5046Z" fill="black" />
                <path d="M14.75 2.75464C14.3358 2.75464 14 3.09043 14 3.50464V14.7546C14.2809 13.5846 15.5143 12.5046 17 12.5046C18.6442 12.5046 19.9794 13.8273 19.9998 15.4666C20.8531 15.2916 21.5224 14.5312 21.464 13.5841C21.231 9.80369 19.8775 6.32566 17.7324 3.47954C17.378 3.00927 16.8265 2.75464 16.2621 2.75464H14.75Z" fill="black" />
                <path d="M18.5 15.5046C18.5 14.6762 17.8284 14.0046 17 14.0046C16.1716 14.0046 15.5 14.6762 15.5 15.5046C15.5 16.3331 16.1716 17.0046 17 17.0046C17.8284 17.0046 18.5 16.3331 18.5 15.5046Z" fill="black" />
            </svg>
            <p class="text-black serviceFeature-Text">Free home delivery on all orders</p>
            <p class="text-black serviceFeature-Text">Next day until 9pm, 7 days a week</p>
        </div>
        <div class="serviceFeature-itemContainer">
            <svg class="serviceFeatureSvg-Icons" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M5.22335 2.25232C4.72607 2.25232 4.24916 2.44986 3.89752 2.80149L2.59835 4.10067C1.13388 5.56514 1.13388 7.9395 2.59835 9.40397C3.93551 10.7411 6.03124 10.8574 7.50029 9.7527C8.12669 10.223 8.90598 10.5023 9.75 10.5023C10.5941 10.5023 11.3736 10.2229 12 9.75248C12.6264 10.2229 13.4059 10.5023 14.25 10.5023C15.094 10.5023 15.8733 10.223 16.4997 9.7527C17.9688 10.8574 20.0645 10.7411 21.4016 9.40397C22.8661 7.9395 22.8661 5.56514 21.4016 4.10067L20.1025 2.8015C19.7508 2.44987 19.2739 2.25232 18.7767 2.25232L5.22335 2.25232Z" fill="black" />
                <path fill-rule="evenodd" clip-rule="evenodd" d="M3 20.2523V11.4974C4.42021 12.1709 6.0799 12.1704 7.50044 11.4967C8.18265 11.8206 8.94611 12.0023 9.75 12.0023C10.5541 12.0023 11.3177 11.8205 12 11.4965C12.6823 11.8205 13.4459 12.0023 14.25 12.0023C15.0539 12.0023 15.8173 11.8206 16.4996 11.4967C17.9201 12.1704 19.5798 12.1709 21 11.4974V20.2523H21.75C22.1642 20.2523 22.5 20.5881 22.5 21.0023C22.5 21.4165 22.1642 21.7523 21.75 21.7523H2.25C1.83579 21.7523 1.5 21.4165 1.5 21.0023C1.5 20.5881 1.83579 20.2523 2.25 20.2523H3ZM6 14.2523C6 13.8381 6.33579 13.5023 6.75 13.5023H9.75C10.1642 13.5023 10.5 13.8381 10.5 14.2523V17.2523C10.5 17.6665 10.1642 18.0023 9.75 18.0023H6.75C6.33579 18.0023 6 17.6665 6 17.2523V14.2523ZM14.25 13.5023C13.8358 13.5023 13.5 13.8381 13.5 14.2523V19.5023C13.5 19.9165 13.8358 20.2523 14.25 20.2523H17.25C17.6642 20.2523 18 19.9165 18 19.5023V14.2523C18 13.8381 17.6642 13.5023 17.25 13.5023H14.25Z" fill="black" />
            </svg>
            <p class="text-black serviceFeature-Text">Free click &amp; collect service</p>
            <p class="text-black serviceFeature-Text">From over 25 showrooms nationwide</p>
        </div>
        <div class="serviceFeature-itemContainer">
            <svg class="serviceFeatureSvg-Icons" viewBox="0 0 20 22" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path fill-rule="evenodd" clip-rule="evenodd" d="M10.5157 1.1698C10.2265 0.895873 9.77353 0.895873 9.48428 1.1698C7.46752 3.07977 4.74624 4.25011 1.75 4.25011C1.27984 4.24515 0.987669 4.4539 0.885415 4.76491C0.472873 6.01968 0.25 7.35963 0.25 8.75015C0.25 14.6922 4.31406 19.6831 9.81306 21.0984C9.93569 21.13 10.0643 21.13 10.1869 21.0984C15.6859 19.6831 19.75 14.6922 19.75 8.75015C19.75 7.35963 19.5271 6.01968 19.1146 4.76491C19.0123 4.4539 18.7202 4.24515 18.3928 4.24922C18.2977 4.24981 18.25 4.25011 18.25 4.25011C15.2538 4.25011 12.5325 3.07977 10.5157 1.1698ZM13.6103 9.18593C13.8511 8.84887 13.773 8.38046 13.4359 8.1397C13.0989 7.89894 12.6305 7.97701 12.3897 8.31407L9.1543 12.8436L7.53033 11.2197C7.23744 10.9268 6.76256 10.9268 6.46967 11.2197C6.17678 11.5126 6.17678 11.9874 6.46967 12.2803L8.71967 14.5303C8.87556 14.6862 9.09215 14.7656 9.31186 14.7474C9.53157 14.7293 9.73216 14.6153 9.8603 14.4359L13.6103 9.18593Z" fill="black" />
            </svg>
            <p class="text-black serviceFeature-Text">Extend your warranty by 3 years</p>
            <p class="text-black serviceFeature-Text">On top of the manufacturer's warranty</p>
        </div>
    </section>

    <!-- Shop By Category -->
    <section id="shopBy-category-Container">
        <div class="title-Container">
            <h5 class="text-black">Shop By Category</h5>
        </div>
        <div id="shopBy-Category-Wrapper">
            <div id="shopBy-Category-leftContainer">
                <div class="shopBy-categoryItem-Left categoryItem"
                     @onmouseenter="() => watchHover = true"
                     @onmouseleave="() => watchHover = false">
                    <div class="categoryItem-Media-Container @(watchHover ? "categoryItem-Media-ContainerActive" : "")">
                        <img class="categoryItem-Media-Watches"
                             src="images/cat-watches.jpg"
                             alt="Watches" />
                    </div>
                    <div class="categoryItem-infoContent-Container">
                        <h5 class="categoryItem-Title @(watchHover ? "categoryItem-titleActive" : "")">Watches</h5>
                        <a class="navLink-categoryItemAnimation" href="watches">Shop Now</a>
                    </div>
                </div>
            </div>
            <div id="shopBy-Category-rightContainer">
                <div class="shopBy-categoryItem-Right categoryItem"
                     @onmouseenter="() => jewelleryHover = true"
                     @onmouseleave="() => jewelleryHover = false">
                    <div class="categoryItem-Media-Container categoryItem-Media-Jewellery @(jewelleryHover ? "categoryItem-Media-ContainerActive" : "")"></div>
                    <div class="categoryItem-infoContent-Container">
                        <h5 class="categoryItem-Title @(jewelleryHover ? "categoryItem-titleActive" : "")">Jewellery</h5>
                        <a class="navLink-categoryItemAnimation" href="jewellery">Shop Now</a>
                    </div>
                </div>
                <div class="shopBy-categoryItem-Right categoryItem"
                     @onmouseenter="() => accessoriesHover = true"
                     @onmouseleave="() => accessoriesHover = false">
                    <div class="categoryItem-Media-Container categoryItem-Media-Accessories @(accessoriesHover ? "categoryItem-Media-ContainerActive" : "")"></div>
                    <div class="categoryItem-infoContent-Container">
                        <h5 class="categoryItem-Title @(accessoriesHover ? "categoryItem-titleActive" : "")">Accessories</h5>
                        <a class="navLink-categoryItemAnimation" href="accessories">Shop Now</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Watch Products Slider -->
    @if (watchProducts.Any())
    {
        <section class="productCard-sliderControls-Container-WatchProducts">
            <div class="title-Container">
                <h5 class="text-black">Popular Watch Products</h5>
                <a href="watches" class="nav-link text-black shopBy-Btn navLink-Animation">
                    Explore All
                    <svg class="shopBy-btnIcon" width="20" height="20" viewBox="0 0 20 20" fill="none"><path fill-rule="evenodd" clip-rule="evenodd" d="M8.21967 5.22431C8.51256 4.93142 8.98744 4.93142 9.28033 5.22431L13.5303 9.47431C13.8232 9.7672 13.8232 10.2421 13.5303 10.535L9.28033 14.785C8.98744 15.0779 8.51256 15.0779 8.21967 14.785C7.92678 14.4921 7.92678 14.0172 8.21967 13.7243L11.9393 10.0046L8.21967 6.28497C7.92678 5.99208 7.92678 5.5172 8.21967 5.22431Z" fill="#0F172A" /></svg>
                </a>
            </div>
            <div class="popular-products-grid">
                @foreach (var p in watchProducts.Take(4))
                {
                    <ProductCard Product="p" />
                }
            </div>
        </section>
    }

    <!-- Watch Brands -->
    <section id="watch-brands-Container">
        <div id="watch-brands-Wrapper">
            <div id="watchBrands-topItem-Container">
                <div class="watchBrands-topItem">
                    <div class="watchBrands-topItem-imgContainer">
                        <div class="watchBrands-topItem-Img"></div>
                    </div>
                    <div class="watchBrands-topItem-Info">
                        <h6 class="text-black watchBrands-topItem-Title">Swiss Automatics</h6>
                        <p class="text-black watchBrands-topItem-Description">Precision movements &amp; timeless craftsmanship.</p>
                        <a href="watches" class="nav-link text-black navLink-Animation watchBrands-topItem-Links">Explore All</a>
                    </div>
                </div>
            </div>
            <div id="watchBrands-bottomItem-Container">
                <div class="watchBrands-bottomItem">
                    <div class="watchBrands-bottomItem-imgContainer">
                        <div class="watchBrands-bottomItem-Img watchBrands-bottomItem-Img-Omega"></div>
                    </div>
                    <div class="watchBrands-bottomItem-Info">
                        <h6 class="text-black watchBrands-bottomItem-Title">Dive Watches</h6>
                        <p class="text-black watchBrands-bottomItem-Description">Robust, water-resistant icons built for depth.</p>
                        <a href="watches" class="nav-link text-black navLink-Animation watchBrands-bottomItem-Links">Explore All</a>
                    </div>
                </div>
                <div class="watchBrands-bottomItem">
                    <div class="watchBrands-bottomItem-imgContainer">
                        <div class="watchBrands-bottomItem-Img watchBrands-bottomItem-Img-TagHeuer"></div>
                    </div>
                    <div class="watchBrands-bottomItem-Info">
                        <h6 class="text-black watchBrands-bottomItem-Title">Chronographs</h6>
                        <p class="text-black watchBrands-bottomItem-Description">Sport-bred timing with motorsport heritage.</p>
                        <a href="watches" class="nav-link text-black navLink-Animation watchBrands-bottomItem-Links">Explore All</a>
                    </div>
                </div>
                <div class="watchBrands-bottomItem">
                    <div class="watchBrands-bottomItem-imgContainer">
                        <div class="watchBrands-bottomItem-Img watchBrands-bottomItem-Img-Tudor"></div>
                    </div>
                    <div class="watchBrands-bottomItem-Info">
                        <h6 class="text-black watchBrands-bottomItem-Title">Everyday Classics</h6>
                        <p class="text-black watchBrands-bottomItem-Description">Refined timepieces for daily elegance.</p>
                        <a href="watches" class="nav-link text-black navLink-Animation watchBrands-bottomItem-Links">Explore All</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Jewellery Products Slider -->
    @if (jewelleryProducts.Any())
    {
        <section class="productCard-sliderControls-Container-JewelleryProducts">
            <div class="title-Container">
                <h5 class="text-black">Popular Jewellery Products</h5>
                <a href="jewellery" class="nav-link text-black shopBy-Btn navLink-Animation">
                    Explore All
                    <svg class="shopBy-btnIcon" width="20" height="20" viewBox="0 0 20 20" fill="none"><path fill-rule="evenodd" clip-rule="evenodd" d="M8.21967 5.22431C8.51256 4.93142 8.98744 4.93142 9.28033 5.22431L13.5303 9.47431C13.8232 9.7672 13.8232 10.2421 13.5303 10.535L9.28033 14.785C8.98744 15.0779 8.51256 15.0779 8.21967 14.785C7.92678 14.4921 7.92678 14.0172 8.21967 13.7243L11.9393 10.0046L8.21967 6.28497C7.92678 5.99208 7.92678 5.5172 8.21967 5.22431Z" fill="#0F172A" /></svg>
                </a>
            </div>
            <div class="popular-products-grid">
                @foreach (var p in jewelleryProducts.Take(4))
                {
                    <ProductCard Product="p" />
                }
            </div>
        </section>
    }

    <!-- Jewellery Categories -->
    <section id="jewellery-category-Container">
        <div class="title-Container">
            <h5 class="text-black">Jewellery Categories</h5>
            <a href="jewellery" class="nav-link text-black shopBy-Btn navLink-Animation">Explore All</a>
        </div>
        <div id="jewellery-category-Wrapper">
            <div class="jewelleryCategory-sliderContainer" id="jewCatSlider">
                <div class="jewelleryCategory-slides" id="jewCatSlides">
                    <div class="jewelleryCategory-slide">
                        <div class="jewelleryCategory-eachSlide-Content">
                            @foreach (var (cls, title) in jewCatSlide1)
                            {
                                <JewelleryCatItem CssClass="@cls" Title="@title" />
                            }
                        </div>
                    </div>
                    <div class="jewelleryCategory-slide">
                        <div class="jewelleryCategory-eachSlide-Content">
                            @foreach (var (cls, title) in jewCatSlide2)
                            {
                                <JewelleryCatItem CssClass="@cls" Title="@title" />
                            }
                        </div>
                    </div>
                    <div class="jewelleryCategory-slide">
                        <div class="jewelleryCategory-eachSlide-Content">
                            @foreach (var (cls, title) in jewCatSlide3)
                            {
                                <JewelleryCatItem CssClass="@cls" Title="@title" />
                            }
                        </div>
                    </div>
                </div>
                <button class="jewelleryCategory-slide-prev" id="jewCatPrev">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path fill-rule="evenodd" clip-rule="evenodd" d="M11.7803 5.22431C12.0732 5.5172 12.0732 5.99208 11.7803 6.28497L8.06066 10.0046L11.7803 13.7243C12.0732 14.0172 12.0732 14.4921 11.7803 14.785C11.4874 15.0779 11.0126 15.0779 10.7197 14.785L6.46967 10.535C6.17678 10.2421 6.17678 9.7672 6.46967 9.47431L10.7197 5.22431C11.0126 4.93142 11.4874 4.93142 11.7803 5.22431Z" fill="red" /></svg>
                </button>
                <button class="jewelleryCategory-slide-next" id="jewCatNext">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path fill-rule="evenodd" clip-rule="evenodd" d="M8.21967 5.22431C8.51256 4.93142 8.98744 4.93142 9.28033 5.22431L13.5303 9.47431C13.8232 9.7672 13.8232 10.2421 13.5303 10.535L9.28033 14.785C8.98744 15.0779 8.51256 15.0779 8.21967 14.785C7.92678 14.4921 7.92678 14.0172 8.21967 13.7243L11.9393 10.0046L8.21967 6.28497C7.92678 5.99208 7.92678 5.5172 8.21967 5.22431Z" fill="red" /></svg>
                </button>
            </div>
        </div>
    </section>

    <!-- Collection Banners -->
    <section id="collection-product-Container">
        <div class="collection-product-Item">
            <div class="collection-product-Wrapper">
                <div class="collection-product-Img collection-product-watchesImg"></div>
                <div class="collection-product-Info">
                    <h1 class="collection-product-Title">Exclusive Watches Collection</h1>
                    <a href="watches" class="nav-link text-black animatedCollection-Links collection-product-exploreAll">Explore All</a>
                </div>
            </div>
        </div>
        <div class="collection-product-Item">
            <div class="collection-product-Wrapper">
                <div class="collection-product-Img collection-product-jewelleryImg"></div>
                <div class="collection-product-Info">
                    <h1 class="collection-product-Title">Exclusive Jewellery Collection</h1>
                    <a href="jewellery" class="nav-link text-black animatedCollection-Links collection-product-exploreAll">Explore All</a>
                </div>
            </div>
        </div>
        <div class="collection-product-Item">
            <div class="collection-product-Wrapper">
                <div class="collection-product-Img collection-product-accessoriesImg"></div>
                <div class="collection-product-Info">
                    <h1 class="collection-product-Title">Accessories</h1>
                    <a href="accessories" class="nav-link text-black animatedCollection-Links collection-product-exploreAll">Explore All</a>
                </div>
            </div>
        </div>
    </section>

    <!-- News -->
    <section id="news-Container">
        <div class="title-Container newsTitle-Container">
            <h5 class="text-black">Latest News</h5>
        </div>
        <div class="news-Wrapper">
            <div class="news-item-Container">
                <div class="news-itemTop-Left">
                    <div class="news-itemTop-Img news-itemTop-Img-1"></div>
                </div>
                <div class="news-itemTop-Right">
                    <h2 class="news-item-Title">Tissot PR516 Chronograph: Crafted for long distance races</h2>
                    <p class="news-item-Info">
                        Lorem Ipsum is simply dummy text of the printing and typesetting industry. Lorem Ipsum has been the industry's standard dummy text ever since the 1500s, when an unknown printer took a galley of type and scrambled it to make a type specimen book.
                        <span class="readMore-Btn">Read More</span>
                    </p>
                </div>
            </div>
            <div class="news-item-Container news-itemBottom-Container">
                <div class="news-itemBottom-Left">
                    <h2 class="news-item-Title text-black">Rolex: Leading the way as an independent Swiss watch manufacturer</h2>
                    <p class="news-item-Info text-black">
                        Lorem Ipsum is simply dummy text of the printing and typesetting industry. Lorem Ipsum has been the industry's standard dummy text ever since the 1500s.
                        <span class="readMore-Btn">Read More</span>
                    </p>
                </div>
                <div class="news-itemBottom-Right">
                    <div class="news-itemTop-Img news-itemTop-Img-2"></div>
                </div>
            </div>
        </div>
    </section>

</div>

@code {
    private List<Product> allProducts = new();
    private List<Product> watchProducts = new();
    private List<Product> jewelleryProducts = new();
    private bool watchHover, jewelleryHover, accessoriesHover;

    private int watchRows => Math.Min(2, (int)Math.Ceiling(watchProducts.Count / 4.0));
    private int jewelleryRows => Math.Min(2, (int)Math.Ceiling(jewelleryProducts.Count / 4.0));

    private static readonly (string, string)[] jewCatSlide1 =
    {
        ("jewelleryCategory-eachItem-ImgMenJewellery", "Mens Jewellery"),
        ("jewelleryCategory-eachItem-ImgWomenJewellery", "Ladies Jewellery"),
        ("jewelleryCategory-eachItem-ImgCollections", "Exclusive Jewellery"),
        ("jewelleryCategory-eachItem-ImgAnklets", "Anklets"),
    };
    private static readonly (string, string)[] jewCatSlide2 =
    {
        ("jewelleryCategory-eachItem-ImgBangles", "Bangles"),
        ("jewelleryCategory-eachItem-ImgBracelets", "Bracelets"),
        ("jewelleryCategory-eachItem-ImgCufflinks", "Cufflinks"),
        ("jewelleryCategory-eachItem-ImgChains", "Chains"),
    };
    private static readonly (string, string)[] jewCatSlide3 =
    {
        ("jewelleryCategory-eachItem-ImgCharms", "Charms"),
        ("jewelleryCategory-eachItem-ImgEarings", "Earrings"),
        ("jewelleryCategory-eachItem-ImgEngagementRings", "Engagement Rings"),
        ("jewelleryCategory-eachItem-ImgNecklaces", "Necklaces"),
    };

    protected override async Task OnInitializedAsync()
    {
        allProducts = await ProductService.GetAllAsync();
        watchProducts = allProducts.Where(p => p.ProductCategory == ProductCategory.Watch).ToList();
        jewelleryProducts = allProducts.Where(p => p.ProductCategory == ProductCategory.Jewellery).ToList();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initHomePage");
        }
    }
}
