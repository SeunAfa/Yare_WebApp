@page "/watches"
@inject IProductService ProductService

<PageTitle>@title — Yare</PageTitle>

<ProductListView Title="@title" Label="Watches" Subtitle="@subtitle"
                 HeroClass="page-hero-watches"
                 Products="filtered" Loading="loading"
                 EmptyMessage="No watches match this selection." />

@code {
    [Parameter, SupplyParameterFromQuery(Name = "view")] public string? View { get; set; }

    private List<Product> allWatches = new();
    private List<Product> filtered = new();
    private bool loading = true;
    private string title = "Watches";
    private string subtitle = "Swiss precision, masterful design. Explore our curated selection.";

    protected override async Task OnInitializedAsync()
    {
        allWatches = await ProductService.GetByCategoryAsync(ProductCategory.Watch);
        loading = false;
        ApplyView();
    }

    protected override void OnParametersSet()
    {
        if (!loading) ApplyView();
    }

    private void ApplyView()
    {
        Func<Product, bool>? predicate = null;
        switch ((View ?? "").ToLowerInvariant())
        {
            case "new-in": title = "New In Watches"; break;
            case "exclusive": title = "Exclusive Watches"; break;
            case "limited-edition": title = "Limited Edition Watches"; break;
            case "mens": title = "Mens Watches"; predicate = p => p.Gender == Gender.Male; break;
            case "ladies": title = "Ladies Watches"; predicate = p => p.Gender == Gender.Female; break;
            case "unisex": title = "Unisex Watches"; predicate = p => p.Gender == Gender.Unisex; break;
            case "best-sellers": title = "Best Sellers"; break;
            case "luxury": title = "Luxury Watches"; break;
            case "diamond": title = "Diamond Watches"; predicate = p => p.ByGemstone == ByGemstone.Diamond; break;
            case "swiss": title = "Swiss Watches"; break;
            case "leather": title = "Leather Watches"; predicate = p => p.WatchStrapType == WatchStrapType.Leather; break;
            case "heritage": title = "Heritage Watches"; break;
            case "pocket": title = "Pocket Watches"; break;
            case "sport": title = "Sport Watches"; break;
            case "dive": title = "Dive Watches"; break;
            case "mechanical": title = "Mechanical Watches"; predicate = p => p.WatchMovement == WatchMovement.Mechanical; break;
            case "automatic": title = "Automatic Watches"; predicate = p => p.WatchMovement == WatchMovement.Automatic; break;
            case "quartz": title = "Quartz Watches"; predicate = p => p.WatchMovement == WatchMovement.Quartz; break;
            case "kinetic": title = "Kinetic Watches"; predicate = p => p.WatchMovement == WatchMovement.Kinetic; break;
            case "eco-drive": title = "Eco-Drive Watches"; predicate = p => p.WatchMovement == WatchMovement.EcoDrive; break;
            default: title = "Watches"; break;
        }
        filtered = predicate == null ? allWatches : allWatches.Where(predicate).ToList();
    }
}
