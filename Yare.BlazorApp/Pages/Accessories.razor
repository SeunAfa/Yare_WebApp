@page "/accessories"
@inject IProductService ProductService

<PageTitle>@title — Yare</PageTitle>

<ProductListView Title="@title" Label="Accessories" Subtitle="@subtitle"
                 HeroClass="page-hero-accessories"
                 Products="filtered" Loading="loading"
                 EmptyMessage="No accessories match this selection." />

@code {
    [Parameter, SupplyParameterFromQuery(Name = "view")] public string? View { get; set; }

    private List<Product> all = new();
    private List<Product> filtered = new();
    private bool loading = true;
    private string title = "Accessories";
    private string subtitle = "Complete your look with our premium watch straps, cases and more.";

    protected override async Task OnInitializedAsync()
    {
        all = await ProductService.GetByCategoryAsync(ProductCategory.Accessory);
        loading = false;
        ApplyView();
    }

    protected override void OnParametersSet()
    {
        if (!loading) ApplyView();
    }

    private void ApplyView()
    {
        Func<Product, bool>? p = null;
        switch ((View ?? "").ToLowerInvariant())
        {
            case "watch-straps": title = "Watch Straps"; p = x => x.AccessoryCategory == AccessoryCategory.WatchStraps; break;
            case "cases-boxes": title = "Cases & Boxes"; p = x => x.AccessoryCategory == AccessoryCategory.CasesAndBoxes; break;
            case "wallets": title = "Wallets"; p = x => x.AccessoryCategory == AccessoryCategory.Wallets; break;
            case "keyrings": title = "Keyrings"; p = x => x.AccessoryCategory == AccessoryCategory.Keyrings; break;
            case "lighters": title = "Lighters"; p = x => x.AccessoryCategory == AccessoryCategory.Lighters; break;
            case "pens": title = "Pens"; p = x => x.AccessoryCategory == AccessoryCategory.Pens; break;
            case "cleaning-products": title = "Cleaning Products"; p = x => x.AccessoryCategory == AccessoryCategory.CleaningProducts; break;
            default: title = "Accessories"; break;
        }
        filtered = p == null ? all : all.Where(p).ToList();
    }
}
