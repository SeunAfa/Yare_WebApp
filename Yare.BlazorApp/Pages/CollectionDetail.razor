@page "/collections/{Id:int}"
@inject IProductService ProductService

<PageTitle>@(collection?.CollectionName ?? "Collection") — Yare</PageTitle>

<ProductListView Title="@(collection?.CollectionName ?? "Collection")"
                 Subtitle="@collection?.Description"
                 HeroStyle="@HeroStyle"
                 Products="products" Loading="loading"
                 ShowBrandFilter="@(collection?.Group != "Brand")"
                 EmptyMessage="No products in this collection yet." />

@code {
    [Parameter] public int Id { get; set; }
    private Collection? collection;
    private List<Product> products = new();
    private bool loading = true;

    private string? HeroStyle => string.IsNullOrWhiteSpace(collection?.ImageUrl) ? null
        : $"background-image:linear-gradient(rgba(0,0,0,0.5),rgba(0,0,0,0.5)),url('{collection!.ImageUrl}');background-size:cover;background-position:center;";

    protected override async Task OnParametersSetAsync()
    {
        loading = true;
        collection = await ProductService.GetCollectionByIdAsync(Id);
        products = await ProductService.GetByCollectionAsync(Id);
        loading = false;
    }
}
