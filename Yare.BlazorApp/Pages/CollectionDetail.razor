@page "/collections/{Id:int}"
@inject IProductService ProductService
@inject ICartService CartService

<PageTitle>@(collection?.CollectionName ?? "Collection") — Yare</PageTitle>

@if (collection != null)
{
    <div class="page-hero">
        <div class="page-hero-content">
            <p class="section-label">Collection</p>
            <h1>@collection.CollectionName</h1>
            <p>@collection.Description</p>
        </div>
    </div>
}

<section class="section-pad">
    <div class="container">
        @if (loading)
        {
            <div class="products-grid">
                @for (int i = 0; i < 8; i++) { <div class="skeleton-card"></div> }
            </div>
        }
        else if (!products.Any())
        {
            <div class="empty-state">
                <i class="bi bi-collection"></i>
                <p>No products in this collection yet.</p>
                <a href="watches" class="btn-yare">Browse Watches</a>
            </div>
        }
        else
        {
            <div class="products-grid">
                @foreach (var p in products)
                {
                    <ProductCard Product="p" OnAddToCart="AddToCart" />
                }
            </div>
        }
    </div>
</section>

@code {
    [Parameter] public int Id { get; set; }
    private Collection? collection;
    private List<Product> products = new();
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        collection = await ProductService.GetCollectionByIdAsync(Id);
        products = await ProductService.GetByCollectionAsync(Id);
        loading = false;
    }

    private async Task AddToCart(Product p) => await CartService.AddToCartAsync(p);
}
