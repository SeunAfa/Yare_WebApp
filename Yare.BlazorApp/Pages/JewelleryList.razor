@page "/jewellery"
@inject IProductService ProductService

<PageTitle>@title — Yare</PageTitle>

<ProductListView Title="@title" Label="Jewellery" Subtitle="@subtitle"
                 HeroClass="page-hero-jewellery"
                 Products="filtered" Loading="loading"
                 EmptyMessage="No jewellery matches this selection." />

@code {
    [Parameter, SupplyParameterFromQuery(Name = "view")] public string? View { get; set; }

    private List<Product> all = new();
    private List<Product> filtered = new();
    private bool loading = true;
    private string title = "Jewellery";
    private string subtitle = "From delicate pendants to statement pieces — find your perfect jewel.";

    protected override async Task OnInitializedAsync()
    {
        all = await ProductService.GetByCategoryAsync(ProductCategory.Jewellery);
        loading = false;
        ApplyView();
    }

    protected override void OnParametersSet()
    {
        if (!loading) ApplyView();
    }

    private void ApplyView()
    {
        Func<Product, bool>? p = null;
        switch ((View ?? "").ToLowerInvariant())
        {
            case "mens": title = "Mens Jewellery"; p = x => x.Gender == Gender.Male; break;
            case "ladies": title = "Ladies Jewellery"; p = x => x.Gender == Gender.Female; break;
            case "exclusive": title = "Exclusive Jewellery"; break;
            case "special-occasion": title = "Special Occasion"; p = x => x.ByOccassion == ByOccassion.SpecialOccasion; break;

            case "anklets": title = "Anklets"; p = x => x.JewelleryCategory == JewelleryCategory.Anklets; break;
            case "bangles": title = "Bangles"; p = x => x.JewelleryCategory == JewelleryCategory.Bangles; break;
            case "bracelets": title = "Bracelets"; p = x => x.JewelleryCategory == JewelleryCategory.Bracelets; break;
            case "brooches": title = "Brooches"; p = x => x.JewelleryCategory == JewelleryCategory.Brooches; break;
            case "cufflinks": title = "Cufflinks"; p = x => x.JewelleryCategory == JewelleryCategory.Cufflinks; break;
            case "chains": title = "Chains"; p = x => x.JewelleryCategory == JewelleryCategory.Chains; break;
            case "charms": title = "Charms"; p = x => x.JewelleryCategory == JewelleryCategory.Charms; break;
            case "earrings": title = "Earrings"; p = x => x.JewelleryCategory == JewelleryCategory.Earrings; break;
            case "engagement-rings": title = "Engagement Rings"; p = x => x.JewelleryCategory == JewelleryCategory.EngagementRings; break;
            case "lockets": title = "Lockets"; p = x => x.JewelleryCategory == JewelleryCategory.Lockets; break;
            case "necklaces": title = "Necklaces"; p = x => x.JewelleryCategory == JewelleryCategory.Necklaces; break;
            case "pendants": title = "Pendants"; p = x => x.JewelleryCategory == JewelleryCategory.Pendants; break;
            case "rings": title = "Rings"; p = x => x.JewelleryCategory == JewelleryCategory.Rings; break;
            case "wedding-rings": title = "Wedding Rings"; p = x => x.JewelleryCategory == JewelleryCategory.WeddingRings; break;

            case "gold": title = "Gold Jewellery"; p = x => x.ByMetal == ByMetal.Gold; break;
            case "white-gold": title = "White Gold Jewellery"; p = x => x.ByMetal == ByMetal.WhiteGold; break;
            case "rose-gold": title = "Rose Gold Jewellery"; p = x => x.ByMetal == ByMetal.RoseGold; break;
            case "silver": title = "Silver Jewellery"; p = x => x.ByMetal == ByMetal.Silver; break;
            case "platinum": title = "Platinum Jewellery"; p = x => x.ByMetal == ByMetal.Platinum; break;

            case "diamond": title = "Diamond Jewellery"; p = x => x.ByGemstone == ByGemstone.Diamond; break;
            case "pearl": title = "Pearl Jewellery"; p = x => x.ByGemstone == ByGemstone.Pearl; break;
            case "ruby": title = "Ruby Jewellery"; p = x => x.ByGemstone == ByGemstone.Ruby; break;
            case "emerald": title = "Emerald Jewellery"; p = x => x.ByGemstone == ByGemstone.Emerald; break;
            case "sapphire": title = "Sapphire Jewellery"; p = x => x.ByGemstone == ByGemstone.Sapphire; break;

            default: title = "Jewellery"; break;
        }
        filtered = p == null ? all : all.Where(p).ToList();
    }
}
