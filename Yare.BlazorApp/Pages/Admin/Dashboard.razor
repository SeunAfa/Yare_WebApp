@page "/admin"
@layout AdminLayout
@inject IProductService ProductService
@inject IOrderService OrderService
@inject IAuthService AuthService

<PageTitle>Dashboard — Yare Admin</PageTitle>

<div class="admin-page-header">
    <h1>Dashboard</h1>
    <p>
        @if (currentUser?.Role == SD.Role_Employee && !string.IsNullOrWhiteSpace(currentUser.StoreName))
        {
            @($"Overview of {currentUser.StoreName}'s performance")
        }
        else
        {
            @("Overview of all stores performance")
        }
    </p>
</div>

@if (loading)
{
    <div class="kpi-grid">
        @for (int i = 0; i < 6; i++) { <div class="kpi-skeleton"></div> }
    </div>
}
else
{
    <!-- KPI Cards -->
    <div class="kpi-grid">
        <div class="kpi-card">
            <div class="kpi-icon kpi-revenue"><i class="bi bi-currency-pound"></i></div>
            <div class="kpi-body">
                <p class="kpi-label">Total Revenue</p>
                <h3 class="kpi-value">@revenue.ToString("C0")</h3>
                <p class="kpi-change @(revenueChange >= 0 ? "positive" : "negative")">
                    <i class="bi @(revenueChange >= 0 ? "bi-arrow-up" : "bi-arrow-down")"></i>
                    @Math.Abs(revenueChange).ToString("F1")% vs last 15 days
                </p>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon kpi-orders"><i class="bi bi-receipt"></i></div>
            <div class="kpi-body">
                <p class="kpi-label">Total Orders</p>
                <h3 class="kpi-value">@totalOrders</h3>
                <p class="kpi-change neutral"><i class="bi bi-dash"></i> All time</p>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon kpi-products"><i class="bi bi-box-seam"></i></div>
            <div class="kpi-body">
                <p class="kpi-label">Total Products</p>
                <h3 class="kpi-value">@totalProducts</h3>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon kpi-pending"><i class="bi bi-clock-history"></i></div>
            <div class="kpi-body">
                <p class="kpi-label">Pending Orders</p>
                <h3 class="kpi-value">@pendingOrders</h3>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon kpi-processing"><i class="bi bi-gear"></i></div>
            <div class="kpi-body">
                <p class="kpi-label">Processing</p>
                <h3 class="kpi-value">@processingOrders</h3>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon kpi-shipped"><i class="bi bi-truck"></i></div>
            <div class="kpi-body">
                <p class="kpi-label">Shipped</p>
                <h3 class="kpi-value">@shippedOrders</h3>
            </div>
        </div>
    </div>

    <!-- Products by Category: mixed bar + line chart (full width) -->
    <div class="admin-card mt-4">
        <h3 class="admin-card-title">Products by Category — Count &amp; Stock Volume</h3>
        <div class="mixed-chart">
            @((MarkupString)chartSvg)
            <div class="chart-legend">
                <span><i class="lg-bar" style="background:#c9a227"></i> Products (count)</span>
                <span><i class="lg-line" style="background:#4fb3c9"></i> Stock volume (units)</span>
            </div>
        </div>
    </div>

    <!-- Best sellers + popular collections (equal height) -->
    <div class="admin-grid-2 dash-charts-grid mt-4">
        <div class="admin-card dash-chart-card">
            <h3 class="admin-card-title">Best-Selling Products</h3>
            @if (bestSellers.Any())
            {
                <div class="rank-chart">@((MarkupString)bestSellersSvg)</div>
            }
            else
            {
                <div class="empty-state"><i class="bi bi-bag"></i><p>No sales recorded yet.</p></div>
            }
        </div>
        <div class="admin-card dash-chart-card">
            <h3 class="admin-card-title">Popular Collections</h3>
            @if (popularCollections.Any())
            {
                <div class="rank-chart">@((MarkupString)collectionsSvg)</div>
            }
            else
            {
                <div class="empty-state"><i class="bi bi-collection"></i><p>No collection sales yet.</p></div>
            }
        </div>
    </div>

    <!-- Order status -->
    <div class="admin-card mt-4">
        <h3 class="admin-card-title">Order Status Breakdown</h3>
        <div class="status-grid">
            @foreach (var (status, count, cls) in orderStatuses)
            {
                <div class="status-pill-box @cls">
                    <span class="status-count">@count</span>
                    <span class="status-name">@status</span>
                </div>
            }
        </div>
    </div>

    <!-- Recent Orders -->
    <div class="admin-card mt-4">
        <div class="admin-card-header">
            <h3 class="admin-card-title">Recent Orders</h3>
            <a href="admin/orders" class="link-sm">View All</a>
        </div>
        <div class="table-responsive">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>#</th><th>Customer</th><th>Date</th><th>Total</th><th>Status</th><th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in recentOrders)
                    {
                        <tr>
                            <td>#@o.Id</td>
                            <td>@o.FirstName @o.LastName</td>
                            <td>@o.OrderDate.ToString("dd MMM yyyy")</td>
                            <td>@o.OrderTotal.ToString("C")</td>
                            <td><span class="status-badge @GetStatusClass(o.OrderStatus)">@o.OrderStatus</span></td>
                            <td>
                                <a href="@($"admin/orders/{o.Id}")" class="link-sm">View</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private bool loading = true;
    private double revenue, revenueChange;
    private int totalOrders, totalProducts, pendingOrders, processingOrders, shippedOrders;
    private List<Product> allProducts = new();
    private List<OrderHeader> allOrders = new();
    private List<OrderHeader> recentOrders = new();
    private List<(string label, int count, int volume, string color)> categoryChart = new();
    private List<(string, int, string)> orderStatuses = new();
    private string chartSvg = "";
    private List<(string label, int units)> bestSellers = new();
    private List<(string label, int units)> popularCollections = new();
    private string bestSellersSvg = "";
    private string collectionsSvg = "";
    private AppUser? currentUser;

    protected override async Task OnInitializedAsync()
    {
        currentUser = await AuthService.GetCurrentUserAsync();
        allProducts = await ProductService.GetAllAsync();
        allOrders = await OrderService.GetAllOrdersAsync();

        totalProducts = allProducts.Count;
        totalOrders = allOrders.Count;
        pendingOrders = allOrders.Count(o => o.OrderStatus == SD.StatusPending);
        processingOrders = allOrders.Count(o => o.OrderStatus == SD.StatusInProcess);
        shippedOrders = allOrders.Count(o => o.OrderStatus == SD.StatusShipped);

        var cutoff = DateTime.Now.AddDays(-15);
        var prev = allOrders.Where(o => o.OrderStatus == SD.StatusShipped && o.OrderDate < cutoff).Sum(o => o.OrderTotal);
        var curr = allOrders.Where(o => o.OrderStatus == SD.StatusShipped && o.OrderDate >= cutoff).Sum(o => o.OrderTotal);
        revenue = allOrders.Where(o => o.OrderStatus == SD.StatusShipped).Sum(o => o.OrderTotal);
        revenueChange = prev == 0 ? 100 : Math.Round(((curr - prev) / Math.Abs(prev)) * 100, 2);

        int VolOf(ProductCategory cat) => allProducts.Where(p => p.ProductCategory == cat).Sum(p => p.Quantity ?? 0);
        categoryChart = new()
        {
            ("Watches", allProducts.Count(p => p.ProductCategory == ProductCategory.Watch), VolOf(ProductCategory.Watch), "#c9a227"),
            ("Jewellery", allProducts.Count(p => p.ProductCategory == ProductCategory.Jewellery), VolOf(ProductCategory.Jewellery), "#b8911f"),
            ("Accessories", allProducts.Count(p => p.ProductCategory == ProductCategory.Accessory), VolOf(ProductCategory.Accessory), "#8f6d14"),
        };

        orderStatuses = new()
        {
            (SD.StatusPending, pendingOrders, "status-pending"),
            (SD.StatusApproved, allOrders.Count(o => o.OrderStatus == SD.StatusApproved), "status-approved"),
            (SD.StatusInProcess, processingOrders, "status-processing"),
            (SD.StatusShipped, shippedOrders, "status-shipped"),
            (SD.StatusCancelled, allOrders.Count(o => o.OrderStatus == SD.StatusCancelled), "status-cancelled"),
            (SD.StatusRefunded, allOrders.Count(o => o.OrderStatus == SD.StatusRefunded), "status-refunded"),
        };

        recentOrders = allOrders.Take(8).ToList();

        await BuildSalesChartsAsync();
        BuildChartSvg();
        loading = false;
    }

    private async Task BuildSalesChartsAsync()
    {
        // Aggregate units sold per product across every order's line items.
        var unitsByProduct = new Dictionary<int, int>();
        foreach (var o in allOrders)
        {
            var dets = await OrderService.GetOrderDetailsAsync(o.Id);
            foreach (var d in dets)
            {
                unitsByProduct[d.ProductId] = unitsByProduct.GetValueOrDefault(d.ProductId) + d.Count;
            }
        }

        var productMap = allProducts.ToDictionary(p => p.Id);
        bestSellers = unitsByProduct
            .OrderByDescending(kv => kv.Value)
            .Take(5)
            .Select(kv => (productMap.GetValueOrDefault(kv.Key)?.ProductName ?? $"#{kv.Key}", kv.Value))
            .ToList();

        // Collection popularity = total units sold of its member products.
        var collections = await ProductService.GetCollectionsAsync();
        popularCollections = collections
            .Select(c => (c.CollectionName ?? $"Collection {c.Id}",
                          c.ProductIds.Sum(pid => unitsByProduct.GetValueOrDefault(pid))))
            .Where(x => x.Item2 > 0)
            .OrderByDescending(x => x.Item2)
            .Take(5)
            .ToList();

        bestSellersSvg = BuildRankChart(bestSellers, "#c9a227");
        collectionsSvg = BuildRankChart(popularCollections, "#c9a227");
    }

    // Horizontal ranked bar chart for a short top-N list.
    private static string BuildRankChart(List<(string label, int units)> data, string color)
    {
        if (!data.Any()) return "";
        int W = 520, rowH = 46, padT = 10, padB = 10, labelW = 170, padR = 50;
        int H = padT + padB + data.Count * rowH;
        int barMaxW = W - labelW - padR;
        int max = Math.Max(1, data.Max(d => d.units));

        var sb = new System.Text.StringBuilder();
        sb.Append($"<svg viewBox=\"0 0 {W} {H}\" xmlns=\"http://www.w3.org/2000/svg\" preserveAspectRatio=\"xMidYMid meet\">");
        for (int i = 0; i < data.Count; i++)
        {
            int y = padT + i * rowH;
            int barH = 22;
            int by = y + (rowH - barH) / 2;
            int barW = (int)Math.Max(3, (double)data[i].units / max * barMaxW);
            var label = data[i].label.Length > 24 ? data[i].label.Substring(0, 23) + "…" : data[i].label;
            sb.Append($"<text x=\"{labelW - 12}\" y=\"{by + 15}\" text-anchor=\"end\" font-size=\"13\" fill=\"rgba(255,255,255,0.82)\">{System.Security.SecurityElement.Escape(label)}</text>");
            sb.Append($"<rect x=\"{labelW}\" y=\"{by}\" width=\"{barMaxW}\" height=\"{barH}\" rx=\"4\" fill=\"rgba(255,255,255,0.06)\"/>");
            sb.Append($"<rect x=\"{labelW}\" y=\"{by}\" width=\"{barW}\" height=\"{barH}\" rx=\"4\" fill=\"{color}\"/>");
            sb.Append($"<text x=\"{labelW + barW + 8}\" y=\"{by + 15}\" text-anchor=\"start\" font-size=\"13\" font-weight=\"600\" fill=\"{color}\">{data[i].units}</text>");
        }
        sb.Append("</svg>");
        return sb.ToString();
    }

    private void BuildChartSvg()
    {
        int maxCount = Math.Max(1, categoryChart.Max(c => c.count));
        int maxVol = Math.Max(1, categoryChart.Max(c => c.volume));
        // round axis maxes up to a "nice" step so tick labels are clean
        int countTop = NiceMax(maxCount), volTop = NiceMax(maxVol);
        int W = 960, H = 320, padL = 48, padR = 56, padT = 30, padB = 50;
        int plotW = W - padL - padR, plotH = H - padT - padB;
        int n = categoryChart.Count;
        double slot = (double)plotW / Math.Max(1, n);
        int barW = (int)Math.Min(140, slot * 0.42);
        const string barColor = "#c9a227", lineColor = "#4fb3c9"; // gold bars, teal line

        var sb = new System.Text.StringBuilder();
        sb.Append($"<svg viewBox=\"0 0 {W} {H}\" xmlns=\"http://www.w3.org/2000/svg\" preserveAspectRatio=\"xMidYMid meet\">");

        // gridlines + dual axis tick labels (left = count, right = stock volume)
        for (int g = 0; g <= 4; g++)
        {
            int gy = padT + plotH - plotH * g / 4;
            sb.Append($"<line x1=\"{padL}\" y1=\"{gy}\" x2=\"{W - padR}\" y2=\"{gy}\" stroke=\"rgba(255,255,255,0.08)\" stroke-width=\"1\"/>");
            int countTick = (int)Math.Round(countTop * g / 4.0);
            int volTick = (int)Math.Round(volTop * g / 4.0);
            sb.Append($"<text x=\"{padL - 9}\" y=\"{gy + 4}\" text-anchor=\"end\" font-size=\"11\" fill=\"{barColor}\">{countTick}</text>");
            sb.Append($"<text x=\"{W - padR + 9}\" y=\"{gy + 4}\" text-anchor=\"start\" font-size=\"11\" fill=\"{lineColor}\">{volTick}</text>");
        }
        // axis captions
        sb.Append($"<text x=\"{padL - 9}\" y=\"{padT - 12}\" text-anchor=\"end\" font-size=\"10\" fill=\"{barColor}\">Count</text>");
        sb.Append($"<text x=\"{W - padR + 9}\" y=\"{padT - 12}\" text-anchor=\"start\" font-size=\"10\" fill=\"{lineColor}\">Units</text>");

        var pts = new List<string>();
        for (int i = 0; i < n; i++)
        {
            int cx = (int)(padL + slot * i + slot / 2);
            int barH = (int)((double)categoryChart[i].count / countTop * plotH);
            int by = padT + plotH - barH;
            int volY = (int)(padT + plotH - (double)categoryChart[i].volume / volTop * plotH);
            pts.Add($"{cx},{volY}");
            sb.Append($"<rect x=\"{cx - barW / 2}\" y=\"{by}\" width=\"{barW}\" height=\"{barH}\" rx=\"3\" fill=\"{barColor}\"/>");
            sb.Append($"<text x=\"{cx}\" y=\"{by - 9}\" text-anchor=\"middle\" font-size=\"14\" font-weight=\"600\" fill=\"{barColor}\">{categoryChart[i].count}</text>");
            sb.Append($"<text x=\"{cx}\" y=\"{H - 16}\" text-anchor=\"middle\" font-size=\"13\" fill=\"rgba(255,255,255,0.7)\">{categoryChart[i].label}</text>");
        }

        sb.Append($"<polyline fill=\"none\" stroke=\"{lineColor}\" stroke-width=\"2.5\" points=\"{string.Join(" ", pts)}\"/>");

        for (int i = 0; i < n; i++)
        {
            int cx = (int)(padL + slot * i + slot / 2);
            int volY = (int)(padT + plotH - (double)categoryChart[i].volume / volTop * plotH);
            sb.Append($"<circle cx=\"{cx}\" cy=\"{volY}\" r=\"5\" fill=\"#1a1a1f\" stroke=\"{lineColor}\" stroke-width=\"2.5\"/>");
            sb.Append($"<text x=\"{cx + 14}\" y=\"{volY + 4}\" text-anchor=\"start\" font-size=\"12\" font-weight=\"600\" fill=\"{lineColor}\">{categoryChart[i].volume}</text>");
        }

        sb.Append("</svg>");
        chartSvg = sb.ToString();
    }

    // round a max value up to a clean axis top (e.g. 7 -> 10, 18 -> 20, 230 -> 300)
    private static int NiceMax(int v)
    {
        if (v <= 5) return 5;
        if (v <= 10) return 10;
        int mag = (int)Math.Pow(10, (int)Math.Floor(Math.Log10(v)));
        return ((v / mag) + 1) * mag;
    }

    private string GetStatusClass(string? status) => status switch
    {
        SD.StatusApproved => "badge-approved",
        SD.StatusPending => "badge-pending",
        SD.StatusInProcess => "badge-processing",
        SD.StatusShipped => "badge-shipped",
        SD.StatusCancelled => "badge-cancelled",
        SD.StatusRefunded => "badge-refunded",
        _ => ""
    };
}
