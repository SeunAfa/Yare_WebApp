@page "/admin/watches"
@layout AdminLayout
@inject IProductService ProductService
@inject NavigationManager Nav
@using Yare.BlazorApp.Models.Enums

<PageTitle>Watches — Yare Admin</PageTitle>

<div class="admin-page-header">
    <div>
        <h1>Watches</h1>
        <p>Manage your watch catalogue</p>
    </div>
    <div class="header-actions">
        <a href="admin/products/edit/0" class="btn-yare"><i class="bi bi-plus-lg"></i> Add Watch</a>
    </div>
</div>

<div class="admin-card">
    <div class="table-toolbar">
        <input type="text" placeholder="Search watches..." value="@searchTerm" @oninput="OnSearchInput" class="search-input" />
        <span class="toolbar-count">@Filtered.Count() of @products.Count</span>
    </div>

    @if (loading)
    {
        <div class="table-skeleton"></div>
    }
    else if (!Filtered.Any())
    {
        <div class="empty-state">
            <i class="bi bi-watch"></i>
            <p>No watches found.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Image</th>
                        <th>Name</th>
                        <th>Ref.</th>
                        <th>Price</th>
                        <th>Stock</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Paged)
                    {
                        <tr>
                            <td><img src="@(p.PrimaryDisplayImageUrl ?? "https://picsum.photos/seed/w/60/60")" class="table-thumb" alt="@p.ProductName" /></td>
                            <td>
                                <div class="table-product-name">@p.ProductName</div>
                                <small>@p.WatchBrand</small>
                            </td>
                            <td>@p.ProductNumber</td>
                            <td>@p.Price.ToString("C")</td>
                            <td><span class="status-badge @GetStockClass(p.StockStatus)">@p.StockStatus</span></td>
                            <td>
                                <div class="table-actions">
                                    <a href="@($"admin/products/edit/{p.Id}")" class="btn-icon" title="Edit"><i class="bi bi-pencil"></i></a>
                                    <a href="@($"product/{p.Id}")" class="btn-icon" title="View details in store front" target="_blank"><i class="bi bi-eye"></i></a>
                                    <button class="btn-icon danger" @onclick="() => ConfirmDelete(p.Id)" title="Delete"><i class="bi bi-trash3"></i></button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <Pagination CurrentPage="currentPage" TotalPages="TotalPages" OnPageChange="(p) => currentPage = p" />
    }
</div>

@if (deleteId > 0)
{
    <div class="modal-overlay">
        <div class="modal-card">
            <h3>Delete Watch?</h3>
            <p>This action cannot be undone in this session.</p>
            <div class="modal-actions">
                <button class="btn-outline-sm" @onclick="() => deleteId = 0">Cancel</button>
                <button class="btn-danger" @onclick="DoDelete">Delete</button>
            </div>
        </div>
    </div>
}

@code {
    private const int PageSize = 10;
    private List<Product> products = new();
    private string searchTerm = "";
    private bool loading = true;
    private int deleteId;
    private int currentPage = 1;

    protected override async Task OnInitializedAsync()
    {
        products = await ProductService.GetByCategoryAsync(ProductCategory.Watch);
        loading = false;
    }

    private IEnumerable<Product> Filtered => products.Where(p =>
        string.IsNullOrEmpty(searchTerm) ||
        (p.ProductName?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
        (p.ProductNumber?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false));

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(Filtered.Count() / (double)PageSize));

    private IEnumerable<Product> Paged
    {
        get
        {
            if (currentPage > TotalPages) currentPage = TotalPages;
            if (currentPage < 1) currentPage = 1;
            return Filtered.Skip((currentPage - 1) * PageSize).Take(PageSize);
        }
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? "";
        currentPage = 1;
    }

    private void ConfirmDelete(int id) => deleteId = id;

    private async Task DoDelete()
    {
        await ProductService.DeleteProductAsync(deleteId);
        products.RemoveAll(p => p.Id == deleteId);
        deleteId = 0;
    }

    private string GetStockClass(string? s) => s switch
    {
        SD.InStock => "badge-shipped",
        SD.RunningLow => "badge-pending",
        _ => "badge-cancelled"
    };
}
