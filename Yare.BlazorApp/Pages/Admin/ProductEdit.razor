@page "/admin/products/edit/{Id:int}"
@layout AdminLayout
@inject IProductService ProductService
@inject NavigationManager Nav

<PageTitle>@(Id == 0 ? "Add" : "Edit") Product — Yare Admin</PageTitle>

<div class="admin-page-header">
    <h1>@(Id == 0 ? "Add New Product" : "Edit Product")</h1>
    <a href="admin/products" class="btn-outline-sm"><i class="bi bi-arrow-left"></i> Back</a>
</div>

@if (loading)
{
    <div class="admin-card"><div class="table-skeleton"></div></div>
}
else
{
    <div class="admin-card">
        <EditForm Model="@product" OnValidSubmit="Save">
            <DataAnnotationsValidator />
            <div class="form-section">
                <h3>Product Type</h3>
                <div class="form-grid">
                    <div class="form-group">
                        <label>Category</label>
                        <InputSelect @bind-Value="product.ProductCategory" @bind-Value:after="SyncGenderCollection" class="form-control">
                            @foreach (var cat in Enum.GetValues<ProductCategory>())
                            {
                                <option value="@cat">@cat</option>
                            }
                        </InputSelect>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <h3>Basic Information</h3>
                <div class="form-grid">
                    <div class="form-group">
                        <label>Product Name</label>
                        <InputText @bind-Value="product.ProductName" class="form-control" placeholder="Product name" />
                    </div>
                    <div class="form-group">
                        <label>Product Number</label>
                        <InputText @bind-Value="product.ProductNumber" class="form-control" placeholder="e.g. YW-001" />
                    </div>
                    <div class="form-group">
                        <label>Model Number</label>
                        <InputText @bind-Value="product.ModelNumber" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>Supplier</label>
                        <InputText @bind-Value="product.Supplier" class="form-control" />
                    </div>
                    <div class="form-group full-width">
                        <label>Description</label>
                        <InputTextArea @bind-Value="product.ProductDescription" class="form-control" rows="3" />
                    </div>
                    <div class="form-group">
                        <label>Gender</label>
                        <InputSelect @bind-Value="product.Gender" @bind-Value:after="SyncGenderCollection" class="form-control">
                            @foreach (var g in Enum.GetValues<Gender>())
                            {
                                <option value="@g">@g.DisplayName()</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="form-group">
                        <label>Warranty</label>
                        <InputSelect @bind-Value="product.WarrantyYears" class="form-control">
                            @foreach (var w in Enum.GetValues<WarrantyYears>())
                            {
                                <option value="@w">@w.DisplayName()</option>
                            }
                        </InputSelect>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <h3>Images</h3>
                <div class="image-editor">
                    <div class="image-preview-main">
                        @if (!string.IsNullOrWhiteSpace(SelectedImageUrl))
                        {
                            <img src="@SelectedImageUrl" alt="@product.ProductName" />
                        }
                        else
                        {
                            <div class="image-preview-empty"><i class="bi bi-image"></i><span>No image</span></div>
                        }
                    </div>
                    <div class="image-thumb-row">
                        <div class="image-thumb-wrap">
                            <button type="button" class="image-thumb @(activeSlot == "primary" ? "active" : "")" @onclick='() => activeSlot = "primary"' title="Primary">
                                @if (!string.IsNullOrWhiteSpace(product.PrimaryDisplayImageUrl)) { <img src="@product.PrimaryDisplayImageUrl" alt="Primary" /> } else { <i class="bi bi-image"></i> }
                            </button>
                            <label class="thumb-toggle">
                                <input type="checkbox" checked="@product.DisplayImageSlots.Contains(0)" @onchange="e => ToggleImageSlot(0, (bool)e.Value!)" />
                                Show
                            </label>
                        </div>
                        <div class="image-thumb-wrap">
                            <button type="button" class="image-thumb @(activeSlot == "secondary" ? "active" : "")" @onclick='() => activeSlot = "secondary"' title="Secondary">
                                @if (!string.IsNullOrWhiteSpace(product.SecondaryDisplayImageUrl)) { <img src="@product.SecondaryDisplayImageUrl" alt="Secondary" /> } else { <i class="bi bi-image"></i> }
                            </button>
                            <label class="thumb-toggle">
                                <input type="checkbox" checked="@product.DisplayImageSlots.Contains(1)" @onchange="e => ToggleImageSlot(1, (bool)e.Value!)" />
                                Show
                            </label>
                        </div>
                        <div class="image-thumb-wrap">
                            <button type="button" class="image-thumb @(activeSlot == "slider1" ? "active" : "")" @onclick='() => activeSlot = "slider1"' title="Slider 1">
                                @if (!string.IsNullOrWhiteSpace(product.SliderImageUrlOne)) { <img src="@product.SliderImageUrlOne" alt="Slider 1" /> } else { <i class="bi bi-image"></i> }
                            </button>
                            <label class="thumb-toggle">
                                <input type="checkbox" checked="@product.DisplayImageSlots.Contains(2)" @onchange="e => ToggleImageSlot(2, (bool)e.Value!)" />
                                Show
                            </label>
                        </div>
                        <div class="image-thumb-wrap">
                            <button type="button" class="image-thumb @(activeSlot == "slider2" ? "active" : "")" @onclick='() => activeSlot = "slider2"' title="Slider 2">
                                @if (!string.IsNullOrWhiteSpace(product.SliderImageUrlTwo)) { <img src="@product.SliderImageUrlTwo" alt="Slider 2" /> } else { <i class="bi bi-image"></i> }
                            </button>
                            <label class="thumb-toggle">
                                <input type="checkbox" checked="@product.DisplayImageSlots.Contains(3)" @onchange="e => ToggleImageSlot(3, (bool)e.Value!)" />
                                Show
                            </label>
                        </div>
                        <div class="image-thumb-wrap">
                            <button type="button" class="image-thumb @(activeSlot == "slider3" ? "active" : "")" @onclick='() => activeSlot = "slider3"' title="Slider 3">
                                @if (!string.IsNullOrWhiteSpace(product.SliderImageUrlThree)) { <img src="@product.SliderImageUrlThree" alt="Slider 3" /> } else { <i class="bi bi-image"></i> }
                            </button>
                            <label class="thumb-toggle">
                                <input type="checkbox" checked="@product.DisplayImageSlots.Contains(4)" @onchange="e => ToggleImageSlot(4, (bool)e.Value!)" />
                                Show
                            </label>
                        </div>
                        <div class="image-thumb-wrap">
                            <button type="button" class="image-thumb @(activeSlot == "slider4" ? "active" : "")" @onclick='() => activeSlot = "slider4"' title="Slider 4">
                                @if (!string.IsNullOrWhiteSpace(product.SliderImageUrlFour)) { <img src="@product.SliderImageUrlFour" alt="Slider 4" /> } else { <i class="bi bi-image"></i> }
                            </button>
                            <label class="thumb-toggle">
                                <input type="checkbox" checked="@product.DisplayImageSlots.Contains(5)" @onchange="e => ToggleImageSlot(5, (bool)e.Value!)" />
                                Show
                            </label>
                        </div>
                    </div>
                    <p class="form-hint">Tick "Show" under any image you want to appear in the storefront gallery for this product. Untick to hide it without deleting the URL.</p>
                    <div class="form-grid">
                        <div class="form-group">
                            <label>Primary Image URL</label>
                            <InputText @bind-Value="product.PrimaryDisplayImageUrl" @bind-Value:event="oninput" class="form-control" placeholder="https://..." />
                        </div>
                        <div class="form-group">
                            <label>Secondary Image URL</label>
                            <InputText @bind-Value="product.SecondaryDisplayImageUrl" @bind-Value:event="oninput" class="form-control" placeholder="https://..." />
                        </div>
                        <div class="form-group">
                            <label>Slider 1</label>
                            <InputText @bind-Value="product.SliderImageUrlOne" @bind-Value:event="oninput" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Slider 2</label>
                            <InputText @bind-Value="product.SliderImageUrlTwo" @bind-Value:event="oninput" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Slider 3</label>
                            <InputText @bind-Value="product.SliderImageUrlThree" @bind-Value:event="oninput" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Slider 4</label>
                            <InputText @bind-Value="product.SliderImageUrlFour" @bind-Value:event="oninput" class="form-control" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <h3>Product Specification</h3>
                @if (product.ProductCategory == ProductCategory.Watch)
                {
                    <div class="form-grid">
                        <div class="form-group">
                            <label>Watch Brand</label>
                            <InputSelect @bind-Value="product.WatchBrand" class="form-control">
                                @foreach (var v in Enum.GetValues<WatchBrand>())
                                {
                                    <option value="@v">@v.DisplayName()</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="form-group">
                            <label>Case Metal</label>
                            <InputSelect @bind-Value="product.ByMetal" class="form-control">
                                @foreach (var v in Enum.GetValues<ByMetal>())
                                {
                                    <option value="@v">@v.DisplayName()</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="form-group">
                            <label>Strap Type</label>
                            <InputSelect @bind-Value="product.WatchStrapType" class="form-control">
                                @foreach (var v in Enum.GetValues<WatchStrapType>())
                                {
                                    <option value="@v">@v.DisplayName()</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="form-group">
                            <label>Strap Colour</label>
                            <InputText @bind-Value="product.StrapColour" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Movement</label>
                            <InputSelect @bind-Value="product.WatchMovement" class="form-control">
                                @foreach (var v in Enum.GetValues<WatchMovement>())
                                {
                                    <option value="@v">@v.DisplayName()</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="form-group">
                            <label>Water Resistance</label>
                            <InputSelect @bind-Value="product.WaterResistant" class="form-control">
                                @foreach (var v in Enum.GetValues<WaterResistant>())
                                {
                                    <option value="@v">@v.DisplayName()</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="form-group">
                            <label>Case Shape</label>
                            <InputSelect @bind-Value="product.WatchCaseShape" class="form-control">
                                @foreach (var v in Enum.GetValues<WatchCaseShape>())
                                {
                                    <option value="@v">@v.DisplayName()</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="form-group">
                            <label>Case Diameter</label>
                            <InputSelect @bind-Value="product.WatchDiameter" class="form-control">
                                @foreach (var v in Enum.GetValues<WatchDiameter>())
                                {
                                    <option value="@v">@v.DisplayName()</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="form-group">
                            <label>Dial Colour</label>
                            <InputText @bind-Value="product.DialColor" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Gemstone</label>
                            <InputSelect @bind-Value="product.ByGemstone" class="form-control">
                                @foreach (var v in Enum.GetValues<ByGemstone>())
                                {
                                    <option value="@v">@v.DisplayName()</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="form-group">
                            <label>Occasion</label>
                            <InputSelect @bind-Value="product.ByOccassion" class="form-control">
                                @foreach (var v in Enum.GetValues<ByOccassion>())
                                {
                                    <option value="@v">@v.DisplayName()</option>
                                }
                            </InputSelect>
                        </div>
                    </div>
                }
                else if (product.ProductCategory == ProductCategory.Jewellery)
                {
                    <div class="form-grid">
                        <div class="form-group">
                            <label>Jewellery Type</label>
                            <InputSelect @bind-Value="product.JewelleryCategory" class="form-control">
                                @foreach (var v in Enum.GetValues<JewelleryCategory>())
                                {
                                    <option value="@v">@v.DisplayName()</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="form-group">
                            <label>Metal</label>
                            <InputSelect @bind-Value="product.ByMetal" class="form-control">
                                @foreach (var v in Enum.GetValues<ByMetal>())
                                {
                                    <option value="@v">@v.DisplayName()</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="form-group">
                            <label>Gemstone</label>
                            <InputSelect @bind-Value="product.ByGemstone" class="form-control">
                                @foreach (var v in Enum.GetValues<ByGemstone>())
                                {
                                    <option value="@v">@v.DisplayName()</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="form-group">
                            <label>Occasion</label>
                            <InputSelect @bind-Value="product.ByOccassion" class="form-control">
                                @foreach (var v in Enum.GetValues<ByOccassion>())
                                {
                                    <option value="@v">@v.DisplayName()</option>
                                }
                            </InputSelect>
                        </div>
                    </div>
                }
                else
                {
                    <div class="form-grid">
                        <div class="form-group">
                            <label>Accessory Type</label>
                            <InputSelect @bind-Value="product.AccessoryCategory" class="form-control">
                                @foreach (var v in Enum.GetValues<AccessoryCategory>())
                                {
                                    <option value="@v">@v.DisplayName()</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="form-group">
                            <label>Metal</label>
                            <InputSelect @bind-Value="product.ByMetal" class="form-control">
                                @foreach (var v in Enum.GetValues<ByMetal>())
                                {
                                    <option value="@v">@v.DisplayName()</option>
                                }
                            </InputSelect>
                        </div>
                    </div>
                }
            </div>

            <div class="form-section">
                <h3>Collections</h3>
                @if (collections.Count == 0)
                {
                    <p class="form-hint">No collections available.</p>
                }
                else
                {
                    <p class="form-hint">Selecting a Gender above automatically ticks the matching audience collection (e.g. Ladies + Jewellery → Ladies Jewellery). You can untick it or add others manually.</p>
                    @foreach (var groupKey in GroupOrder)
                    {
                        var groupItems = collections.Where(c => (c.Group ?? "General") == groupKey).ToList();
                        if (groupItems.Count == 0) { continue; }
                        <div class="checkbox-group">
                            <h4 class="checkbox-group-label">@GroupLabel(groupKey)</h4>
                            <div class="checkbox-grid">
                                @foreach (var c in groupItems)
                                {
                                    <label class="checkbox-pill">
                                        <input type="checkbox" checked="@product.CollectionIds.Contains(c.Id)" @onchange="e => ToggleCollection(c.Id, (bool)e.Value!)" />
                                        @c.CollectionName
                                    </label>
                                }
                            </div>
                        </div>
                    }
                }
            </div>

            <div class="form-section">
                <h3>Margin by Price Tier</h3>
                <div class="margin-chart">
                    @((MarkupString)marginChartSvg)
                    <div class="chart-legend">
                        <span><i class="lg-bar" style="background:#3aa66b"></i> Healthy (≥40%)</span>
                        <span><i class="lg-bar" style="background:#c9a227"></i> Moderate (20–40%)</span>
                        <span><i class="lg-bar" style="background:#d4111e"></i> Low (&lt;20%)</span>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <h3>Pricing &amp; Stock</h3>
                <p class="form-hint">Tiers are discounts off the RRP / base price. Use <strong>Apply</strong> to set the selling Price to a tier, or <strong>Full</strong> for the RRP — the tiers stay anchored to the RRP, so you can switch between them freely.</p>
                <div class="form-grid">
                    <div class="form-group">
                        <label>Cost (£)</label>
                        <InputNumber @bind-Value="product.CostOfProduct" @bind-Value:after="RecalculateFromCost" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>Was Price / RRP (£)</label>
                        <div class="tier-apply-row">
                            <InputNumber @bind-Value="product.PriceWas" @bind-Value:after="RecalculateTiers" class="form-control" />
                            <button type="button" class="btn-tier-apply" @onclick="() => ApplyTier(0)" title="Set the selling price to the full RRP">Full</button>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Price (£) — selling</label>
                        <InputNumber @bind-Value="product.Price" @bind-Value:after="OnPriceChanged" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>Price Tier 1 (-5%)</label>
                        <div class="tier-apply-row">
                            <InputNumber @bind-Value="product.TargetPrice01" class="form-control" readonly />
                            <button type="button" class="btn-tier-apply" @onclick="() => ApplyTier(1)" title="Set this tier as the selling price">Apply</button>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Price Tier 2 (-10%)</label>
                        <div class="tier-apply-row">
                            <InputNumber @bind-Value="product.TargetPrice02" class="form-control" readonly />
                            <button type="button" class="btn-tier-apply" @onclick="() => ApplyTier(2)" title="Set this tier as the selling price">Apply</button>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Price Tier 3 (-25%)</label>
                        <div class="tier-apply-row">
                            <InputNumber @bind-Value="product.TargetPrice03" class="form-control" readonly />
                            <button type="button" class="btn-tier-apply" @onclick="() => ApplyTier(3)" title="Set this tier as the selling price">Apply</button>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Quantity</label>
                        <InputNumber @bind-Value="product.Quantity" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>Remaining Qty</label>
                        <InputNumber @bind-Value="product.RemainigQuantity" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>Stock Status</label>
                        <InputSelect @bind-Value="product.StockStatus" class="form-control">
                            <option value="@SD.InStock">In Stock</option>
                            <option value="@SD.RunningLow">Running Low</option>
                            <option value="@SD.OutOfStock">Out of Stock</option>
                        </InputSelect>
                    </div>
                </div>
            </div>

            @if (saved)
            {
                <div class="alert-success"><i class="bi bi-check-circle"></i> Product saved successfully!</div>
            }
            <ValidationSummary />
            <div class="form-actions">
                <a href="admin/products" class="btn-outline-sm">Cancel</a>
                <button type="submit" class="btn-yare" disabled="@saving">
                    @(saving ? "Saving..." : (Id == 0 ? "Create Product" : "Save Changes"))
                </button>
            </div>
        </EditForm>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }
    private Product product = new() { StockStatus = SD.InStock, ProductCategory = ProductCategory.Watch };
    private List<Collection> collections = new();
    private bool loading = true, saving, saved;
    private string activeSlot = "primary";

    private string? SelectedImageUrl => activeSlot switch
    {
        "primary" => product.PrimaryDisplayImageUrl,
        "secondary" => product.SecondaryDisplayImageUrl,
        "slider1" => product.SliderImageUrlOne,
        "slider2" => product.SliderImageUrlTwo,
        "slider3" => product.SliderImageUrlThree,
        "slider4" => product.SliderImageUrlFour,
        _ => product.PrimaryDisplayImageUrl
    };

    protected override async Task OnInitializedAsync()
    {
        if (Id != 0)
        {
            product = await ProductService.GetByIdAsync(Id) ?? product;
        }
        collections = await ProductService.GetCollectionsAsync();
        if (Id != 0 && product.CollectionIds.Count == 0)
        {
            product.CollectionIds = collections.Where(c => c.ProductIds.Contains(Id)).Select(c => c.Id).ToList();
        }
        if (product.DisplayImageSlots.Count == 0)
        {
            var urls = new[]
            {
                product.PrimaryDisplayImageUrl, product.SecondaryDisplayImageUrl,
                product.SliderImageUrlOne, product.SliderImageUrlTwo, product.SliderImageUrlThree, product.SliderImageUrlFour
            };
            for (int i = 0; i < urls.Length; i++)
            {
                if (!string.IsNullOrWhiteSpace(urls[i])) product.DisplayImageSlots.Add(i);
            }
        }
        // Ensure a stable RRP / base for the price tiers; tiers and "Full" derive from this.
        if (product.PriceWas <= 0)
        {
            product.PriceWas = product.Price;
        }
        RecalculateTiers(); // anchor tiers to the base and draw the margin chart
        loading = false;
    }

    private void ToggleCollection(int id, bool isChecked)
    {
        if (isChecked)
        {
            if (!product.CollectionIds.Contains(id)) product.CollectionIds.Add(id);
        }
        else
        {
            product.CollectionIds.Remove(id);
        }
    }

    private void ToggleImageSlot(int slot, bool isChecked)
    {
        if (isChecked)
        {
            if (!product.DisplayImageSlots.Contains(slot)) product.DisplayImageSlots.Add(slot);
        }
        else
        {
            product.DisplayImageSlots.Remove(slot);
        }
    }

    // ─── Collection grouping ───
    private static readonly string[] GroupOrder = { "Audience", "General", "Featured", "Brand" };

    private static string GroupLabel(string key) => key switch
    {
        "Audience" => "By Audience",
        "Brand" => "By Brand",
        _ => key
    };

    // Audience collections that are auto-managed by the Gender + Category selection.
    private static readonly string[] GenderCollectionNames =
        { "Mens Watches", "Ladies Watches", "Unisex Watches", "Mens Jewellery", "Ladies Jewellery" };

    private void SyncGenderCollection()
    {
        // Clear any previously auto-added gender/category collection, then add the one matching the current selection.
        var genderCollIds = collections
            .Where(c => GenderCollectionNames.Contains(c.CollectionName))
            .Select(c => c.Id)
            .ToList();
        product.CollectionIds.RemoveAll(id => genderCollIds.Contains(id));

        var name = GetGenderCollectionName();
        if (name != null)
        {
            var match = collections.FirstOrDefault(c => c.CollectionName == name);
            if (match != null && !product.CollectionIds.Contains(match.Id))
            {
                product.CollectionIds.Add(match.Id);
            }
        }
    }

    private string? GetGenderCollectionName()
    {
        if (product.Gender == null || product.ProductCategory == null) return null;

        string? genderWord = product.Gender switch
        {
            Gender.Male => "Mens",
            Gender.Female => "Ladies",
            Gender.Unisex => "Unisex",
            _ => null
        };
        string? catWord = product.ProductCategory switch
        {
            ProductCategory.Watch => "Watches",
            ProductCategory.Jewellery => "Jewellery",
            _ => null  // Accessories have no gender-specific collection
        };

        if (genderWord == null || catWord == null) return null;
        return $"{genderWord} {catWord}";  // e.g. "Ladies Jewellery", "Mens Watches"
    }

    private void ApplyTier(int tier)
    {
        // Sets the selling price to the chosen point. Tiers stay anchored to the RRP (no recompute),
        // so you can freely switch between Full price and tiers 1–3 without compounding.
        product.Price = tier switch
        {
            0 => product.PriceWas,        // Full price / RRP
            1 => product.TargetPrice01,
            2 => product.TargetPrice02,
            3 => product.TargetPrice03,
            _ => product.Price
        };
        BuildMarginChart();
    }

    private void RecalculateFromCost()
    {
        // Cost-plus markup establishes the RRP / base price; selling price defaults to the full RRP.
        product.PriceWas = Math.Round(product.CostOfProduct * 1.75, 2);
        product.Price = product.PriceWas;
        RecalculateTiers();
    }

    private void RecalculateTiers()
    {
        // Tiers are anchored to the RRP / base price (PriceWas), NOT the live selling price,
        // so applying a tier never shifts the other tiers and they never compound.
        product.TargetPrice01 = Math.Round(product.PriceWas * 0.95, 2);
        product.TargetPrice02 = Math.Round(product.PriceWas * 0.90, 2);
        product.TargetPrice03 = Math.Round(product.PriceWas * 0.75, 2);
        BuildMarginChart();
    }

    private void OnPriceChanged() => BuildMarginChart();

    private string marginChartSvg = "";

    private void BuildMarginChart()
    {
        var tiers = new (string label, double price)[]
        {
            ("Price", product.Price),
            ("Tier 1", product.TargetPrice01),
            ("Tier 2", product.TargetPrice02),
            ("Tier 3", product.TargetPrice03),
        };

        const int W = 1000, H = 340, padL = 60, padR = 30, padT = 30, padB = 56;
        const int plotW = W - padL - padR, plotH = H - padT - padB;
        double slot = (double)plotW / tiers.Length;
        int barW = (int)Math.Min(160, slot * 0.5);

        var sb = new System.Text.StringBuilder();
        sb.Append($"<svg viewBox=\"0 0 {W} {H}\" xmlns=\"http://www.w3.org/2000/svg\" preserveAspectRatio=\"xMidYMid meet\">");

        for (int g = 0; g <= 4; g++)
        {
            int gy = padT + plotH - plotH * g / 4;
            sb.Append($"<line x1=\"{padL}\" y1=\"{gy}\" x2=\"{W - padR}\" y2=\"{gy}\" stroke=\"rgba(255,255,255,0.08)\" stroke-width=\"1\"/>");
            sb.Append($"<text x=\"{padL - 12}\" y=\"{gy + 5}\" text-anchor=\"end\" font-size=\"14\" fill=\"rgba(255,255,255,0.4)\">{g * 25}%</text>");
        }

        for (int i = 0; i < tiers.Length; i++)
        {
            var (label, price) = tiers[i];
            double margin = price > 0 ? (price - product.CostOfProduct) / price * 100 : 0;
            double clamped = Math.Max(0, Math.Min(100, margin));
            int cx = (int)(padL + slot * i + slot / 2);
            int barH = (int)(clamped / 100 * plotH);
            int by = padT + plotH - barH;
            string color = margin >= 40 ? "#3aa66b" : margin >= 20 ? "#c9a227" : "#d4111e";
            sb.Append($"<rect x=\"{cx - barW / 2}\" y=\"{by}\" width=\"{barW}\" height=\"{barH}\" rx=\"4\" fill=\"{color}\"/>");
            sb.Append($"<text x=\"{cx}\" y=\"{by - 12}\" text-anchor=\"middle\" font-size=\"18\" font-weight=\"600\" fill=\"#fff\">{margin:F0}%</text>");
            sb.Append($"<text x=\"{cx}\" y=\"{H - 34}\" text-anchor=\"middle\" font-size=\"15\" font-weight=\"600\" fill=\"rgba(255,255,255,0.85)\">{label}</text>");
            sb.Append($"<text x=\"{cx}\" y=\"{H - 14}\" text-anchor=\"middle\" font-size=\"13\" fill=\"rgba(255,255,255,0.45)\">£{price:F0} (+£{(price - product.CostOfProduct):F0})</text>");
        }

        sb.Append("</svg>");
        marginChartSvg = sb.ToString();
    }

    private async Task Save()
    {
        saving = true;
        await ProductService.SaveProductAsync(product);
        saved = true;
        saving = false;
        await Task.Delay(2000);
        Nav.NavigateTo("admin/products");
    }
}
